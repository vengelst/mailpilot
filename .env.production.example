# MailPilot production environment template — copy to .env.production and fill real values.
# .env.production is gitignored. NEVER commit real secrets.

NODE_ENV=production

# --- PostgreSQL ---
# `db` is the Compose service name. POSTGRES_PASSWORD must match what Postgres uses.
DATABASE_URL=postgresql://mailpilot:CHANGE_ME@db:5432/mailpilot?schema=public

POSTGRES_USER=mailpilot
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mailpilot

# --- App secrets ---
# 64 hex chars = 32 bytes for AES-256.
APP_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
# Long random string (e.g. `openssl rand -hex 48`).
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# --- AI provider ---
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Public URL (used in OAuth redirects, email links, etc.) ---
NEXT_PUBLIC_APP_URL=https://mailpilot.vivahome.de

# --- Cloud OAuth (leave empty until configured) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://mailpilot.vivahome.de/api/cloud/oauth/callback
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=https://mailpilot.vivahome.de/api/cloud/oauth/callback
CLOUD_OAUTH_ALLOW_STUB=false
