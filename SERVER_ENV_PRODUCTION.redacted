# Redigierte Kopie der Server-Datei /opt/mailpilot/.env.production
# Stand: 2026-05-03
#
# Diese Datei dient nur zur Nachvollziehbarkeit der Server-Konfiguration.
# Echte Secrets bleiben ausschliesslich auf dem Server in .env.production.

NODE_ENV=production

# PostgreSQL
DATABASE_URL=<SERVER_DATABASE_URL_REDACTED>
POSTGRES_USER=mailpilot
POSTGRES_PASSWORD=<SERVER_SECRET_REDACTED>
POSTGRES_DB=mailpilot

# App secrets
# Muss exakt 64 Hex-Zeichen haben, sonst koennen IMAP/SMTP-Passwoerter nicht verschluesselt werden.
APP_ENCRYPTION_KEY=<SERVER_SECRET_64_HEX_CHARS>
SESSION_SECRET=<SERVER_SECRET_REDACTED>

# AI provider
AI_PROVIDER=mock
OPENAI_API_KEY=<SERVER_SECRET_REDACTED_OR_EMPTY>
ANTHROPIC_API_KEY=<SERVER_SECRET_REDACTED_OR_EMPTY>

# Public URL
NEXT_PUBLIC_APP_URL=https://mailpilot.vivahome.de

# Cloud OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=<SERVER_SECRET_REDACTED_OR_EMPTY>
GOOGLE_REDIRECT_URI=https://mailpilot.vivahome.de/api/cloud/oauth/callback
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=<SERVER_SECRET_REDACTED_OR_EMPTY>
ONEDRIVE_REDIRECT_URI=https://mailpilot.vivahome.de/api/cloud/oauth/callback
CLOUD_OAUTH_ALLOW_STUB=false
